# Firebase の設定値（Firebase コンソール → プロジェクト設定 → 全般 → マイアプリ で確認）
# このファイルをコピーして「.env」を作成し、実際の値を入れてください。
#   PowerShell:  Copy-Item .env.example .env
# ※ Vite では VITE_ 接頭辞の付いた変数だけがクライアントに公開されます。
# ※ .env は .gitignore 済み（リポジトリにコミットされません）。

VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=hoisapo-pj.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=hoisapo-pj
VITE_FIREBASE_STORAGE_BUCKET=hoisapo-pj.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID_HERE
VITE_FIREBASE_APP_ID=YOUR_APP_ID_HERE
